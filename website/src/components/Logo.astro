---
// Theme-aware logo. The rect fill and icon stroke are driven by CSS variables
// (--logo-bg, --logo-fg) which are defined per-theme in global.css.
interface Props { size?: number }
const { size = 28 } = Astro.props as Props
---
<svg class="site-logo" width={size} height={size} viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <rect class="site-logo-bg" width="32" height="32" rx="7" />
  <g class="site-logo-icon" transform="translate(4 4)" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 7v14"/>
    <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>
  </g>
</svg>
