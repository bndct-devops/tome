---
import { DOCS_NAV } from './docs-nav'
import { withBase, stripBase } from '../lib/path'
const path = stripBase(Astro.url.pathname)
const normalize = (p: string) => p.replace(/\/$/, '')
const isActive = (href: string) => normalize(path) === normalize(href)
---
<aside class="docs-sidebar">
  <nav class="docs-nav">
    {DOCS_NAV.map(group => (
      <div class="docs-nav-group">
        <div class="docs-nav-label">{group.label}</div>
        <ul>
          {group.items.map(item => (
            <li>
              <a
                href={withBase(item.href)}
                class={`docs-nav-link ${isActive(item.href) ? 'is-active' : ''}`}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
