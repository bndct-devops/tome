---
// Renders a Mermaid diagram. Pass the diagram source via the `chart` prop or the slot.
// Mermaid is loaded once per page from CDN (small) and re-rendered on theme change.
interface Props { chart?: string }
const { chart } = Astro.props as Props
const id = `mermaid-${Math.random().toString(36).slice(2, 8)}`
---
<div class="docs-mermaid">
  <pre id={id} class="mermaid">{chart ?? Astro.slots.has('default') ? chart : ''}{!chart && <slot />}</pre>
</div>
<script>
  // One-time loader. Re-renders on theme change.
  async function ensureMermaid() {
    if ((window as any).__mermaidReady) return (window as any).__mermaid
    const mod = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs' as any)
    const mermaid = mod.default
    const isDark = document.documentElement.classList.contains('theme-dark')
    mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'neutral', securityLevel: 'loose' })
    ;(window as any).__mermaid = mermaid
    ;(window as any).__mermaidReady = true
    return mermaid
  }
  async function renderAll() {
    const mermaid = await ensureMermaid()
    const nodes = document.querySelectorAll('pre.mermaid:not([data-rendered])')
    for (const node of Array.from(nodes)) {
      try {
        const { svg } = await mermaid.render(`r-${Math.random().toString(36).slice(2)}`, node.textContent || '')
        node.innerHTML = svg
        ;(node as HTMLElement).dataset.rendered = '1'
      } catch (e) { /* leave the source visible if it fails */ }
    }
  }
  renderAll()
  // Re-render on theme change (simple: just reload the page-level mermaid theme + redraw)
  document.addEventListener('tome:theme', () => {
    document.querySelectorAll('pre.mermaid[data-rendered]').forEach(n => {
      const html = (n as HTMLElement).dataset.source
      if (html) { n.textContent = html; (n as HTMLElement).removeAttribute('data-rendered') }
    })
    ;(window as any).__mermaidReady = false
    renderAll()
  })
</script>
